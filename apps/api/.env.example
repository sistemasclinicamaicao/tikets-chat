# Copiar a .env y ajustar valores locales / producción.
DATABASE_URL="postgresql://tickets_user:tickets_pass@127.0.0.1:5432/tickets_db?schema=public"

# API
PORT=3030
API_PREFIX=api/v1

# Logs Nest (coma-separado): error,warn,log,debug,verbose
# LOG_LEVEL=error,warn,log

# Auditoría: eventos de dominio JSON en stdout (deshabilitar con false)
AUDIT_LOG_ENABLED=true

# Log de cada request HTTP como JSON (opt-in; no registra body ni Authorization)
# HTTP_ACCESS_LOG=true
# Rutas que contienen estos fragmentos se omiten (coma-separada)
# HTTP_ACCESS_LOG_SKIP_PATHS=/health,/docs

# JWT: usar el MISMO JWT_SECRET en REST (JwtStrategy) y en Socket.IO (chat.gateway).
# En producción nunca dejar el valor por defecto dev_jwt_secret.
JWT_SECRET=dev_jwt_secret
JWT_REFRESH_SECRET=dev_refresh_secret_change_me

# OTP: employee_id listados (coma-separados) no reciben correo; el login usa verify con código fijo de 6 caracteres.
# Por defecto el API incluye 910204052230; aquí puede añadir más o documentar el código acordado con el front.
# AUTH_OTP_BYPASS_EMPLOYEE_IDS=910204052230
# AUTH_OTP_BYPASS_VERIFY_CODE=000000

# Cifrado de credenciales de integraciones API externas (admin). Mínimo 16 caracteres; en producción use valor aleatorio largo.
# Si falta o es corta, no se podrán crear ni actualizar integraciones (lectura/borrado puede seguir según implementación).
# INTEGRATIONS_ENCRYPTION_KEY=cambie_esto_por_una_cadena_larga_y_aleatoria

# MinIO (S3 compatible) — adjuntos de chat
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_BUCKET=helpdesk
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1

# SMTP (OTP y notificaciones de ticket/chat). Si falta remitente o destinatario, los correos de notificación quedan en `notification_logs` como failed/skipped según el caso.
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@example.com

# URL pública del front (sin barra final) para enlaces si activas correo transaccional de tickets.
# PUBLIC_APP_URL=http://localhost:5173

# En true el API envía correos de tickets (creado, asignación, estado, cierre). El chat nunca envía correo; solo OTP usa correo.
# ENABLE_NON_OTP_EMAIL=true
