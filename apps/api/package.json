{
  "name": "@chat-tikets/api",
  "version": "0.1.0",
  "description": "Backend NestJS para sistema empresarial de tickets, chat e inventario",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true}); try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "node ../../scripts/free-port.mjs 3030 && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "seed:root": "ts-node -r tsconfig-paths/register prisma/ensure-root-user.ts",
    "seed:tickets": "prisma db seed",
    "import:employees": "ts-node -r tsconfig-paths/register prisma/import-employees-list.ts",
    "import:legacy-hv-pc": "ts-node -r tsconfig-paths/register prisma/import-legacy-hv-pc.ts",
    "backfill:gth-photos-to-db": "ts-node -r tsconfig-paths/register prisma/backfill-gth-photos-to-db.ts",
    "export:gth-fotos-html": "ts-node -r tsconfig-paths/register prisma/export-gth-photos-html.ts",
    "clear:gth-comunicaciones-photos": "ts-node -r tsconfig-paths/register prisma/clear-gth-comunicaciones-photos.ts",
    "sync:gth-photos-mysql": "ts-node -r tsconfig-paths/register prisma/sync-gth-photos-to-mysql.ts",
    "rename:gth-photo-filenames": "ts-node -r tsconfig-paths/register prisma/rename-gth-photo-filenames.ts",
    "seed:inventory": "ts-node -r tsconfig-paths/register prisma/seed-inventory-sistemas.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "firebase-admin": "^12.7.0",
    "mysql2": "^3.14.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.1",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
