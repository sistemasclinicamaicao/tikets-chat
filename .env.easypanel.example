# Web build/runtime
WEB_PORT=8080
VITE_API_ORIGIN=https://tu-dominio-api-o-proxy

# API producción (obligatorio en EasyPanel)
NODE_ENV=production
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=https://py3-chat.tjgwxu.easypanel.host,http://localhost:5173

# PostgreSQL
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=change_me_postgres

# Redis
REDIS_PASSWORD=change_me_redis

# JWT
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=12h

# QuObjects / MinIO (S3 compatible)
# Defina una sola vez MINIO_ENDPOINT. Si EasyPanel debe hablar directo con la IP pública del QNAP,
# las pruebas del proyecto mostraron que HTTP falla y HTTPS responde con certificado autofirmado.
MINIO_ENDPOINT=https://179.60.240.86:8010
MINIO_BUCKET=archivos_chat
MINIO_ACCESS_KEY=change_me_access_key
MINIO_SECRET_KEY=change_me_secret_key
MINIO_REGION=colombia
STORAGE_SIGNED_URL_EXPIRES_SECONDS=3600
# Si el certificado TLS del QNAP no es confiable desde EasyPanel, habilite temporalmente esta línea.
# Cuando el DDNS/certificado sean válidos, vuelva a comentarla o elimínela.
# STORAGE_TLS_REJECT_UNAUTHORIZED=false
STORAGE_CONNECT_TIMEOUT_MS=5000
STORAGE_SOCKET_TIMEOUT_MS=10000
STORAGE_MAX_ATTEMPTS=2
CHAT_ATTACHMENT_IMAGE_MAX_MB=10
CHAT_ATTACHMENT_VIDEO_MAX_MB=100
CHAT_ATTACHMENT_FILE_MAX_MB=25

# Admin / integraciones (mín. 16 caracteres)
INTEGRATIONS_ENCRYPTION_KEY=change_me_min_16_chars_integrations_key
LOG_LEVEL=error,warn,log
AUDIT_LOG_ENABLED=true
# HTTP_ACCESS_LOG=true
# HTTP_ACCESS_LOG_SKIP_PATHS=/health,/ready,/docs

# Metadata opcional de build para verificar qué imagen corre en runtime
# BUILD_GIT_SHA=
# BUILD_TIME=
# BUILD_SOURCE_API=compose-root-api

# Correo OTP (opcional; MAIL_PASSWORD mejor como secreto en el panel)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# El correo solo se usa para OTP. Tickets y chat no envían correos.

# MySQL Hostinger — réplica de fotos GTH (Comunicaciones)
# Crear tabla con infrastructure/mysql/gth_fotos.sql en phpMyAdmin.
# Remote MySQL: whitelist IP EasyPanel 179.60.240.86
GTH_MYSQL_ENABLED=false
GTH_MYSQL_HOST=srv1082.hstgr.io
# Alternativa: GTH_MYSQL_HOST=193.203.175.11
GTH_MYSQL_PORT=3306
GTH_MYSQL_DATABASE=u680603156_fotos
GTH_MYSQL_USER=u680603156_cmaicao
GTH_MYSQL_PASSWORD=change_me_mysql
GTH_MYSQL_CONNECT_TIMEOUT_MS=8000
GTH_MYSQL_MAX_SYNC_ATTEMPTS=20
# GTH_MYSQL_SYNC_RETRY_CRON=0 */10 * * * *
# Solo true durante mantenimiento (recrea tabla gth_fotos — destructivo)
# GTH_MYSQL_ALLOW_ENSURE_SCHEMA=false

# Desactivar bypass OTP en producción (recomendado)
# AUTH_OTP_BYPASS_DISABLED=true
# ROOT_EMPLOYEE_IDS=910204052230
